with "project_name.gpr";

project Project_Name_Tests is
   for Source_Dirs use ("tests");
   for Object_Dir use "build/tests/obj";
   for Exec_Dir use "build/tests/bin";
   for Create_Missing_Dirs use "True";
   for Main use ("project_name_tests.adb");

   package Builder is
      for Global_Configuration_Pragmas use "gnat.adc";
   end Builder;

   package Compiler is
      for Default_Switches ("Ada") use Project_Name.Ada_Compiler_Switches;
   end Compiler;

   package Binder is
      for Switches ("Ada") use ("-Es");
   end Binder;

end Project_Name_Tests;
