# Intent: ignore generated/local artifacts only. Keep lockfiles, fixtures,
# corpora, examples, Makefiles, and shared editor config visible by default.

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Editor temporary files, not editor project config
*.swp
*.swo
*~
.#*

# Local environment/secrets
.env
.env.*
!.env.example
!.env.sample
!.env.template

# Logs and temporary files
*.log
*.tmp
*.temp
/.tmp/
/tmp/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Dependency directories
/node_modules/
/vendor/

# Generic generated output
/.cache/
/build/
/coverage/
/dist/
/out/

# JavaScript / TypeScript
*.tsbuildinfo
.eslintcache
/.angular/
/.astro/
/.next/
/.nuxt/
/.nyc_output/
/.parcel-cache/
/.svelte-kit/
/.turbo/
/.vite/

# PHP
/.deptrac.cache
/.infection/
/.pdepend/
/.php-cs-fixer.cache
/.php-cs-fixer.php.cache
/.phpbench/
/.phpunit.cache/
/.phpunit.result.cache
/.phpstan.cache/
/.psalm-cache/
/.psalm/cache/
/.rector-cache/
/composer.phar
/var/cache/
/var/log/
infection-summary.log
infection.log

# C# / .NET
/.vs/
/artifacts/
/TestResults/
**/[Bb]in/[Dd]ebug/
**/[Bb]in/[Rr]elease/
**/[Oo]bj/
*.nupkg
*.pdb
*.snupkg
*.sln.docstates
*.suo
*.user
*.userosscache

# C / CMake
/CMakeCache.txt
/CMakeFiles/
/CTestTestfile.cmake
/DartConfiguration.tcl
/Testing/
/cmake_install.cmake
/compile_commands.json
*.a
*.dll
*.dylib
*.exe
*.gcda
*.gcno
*.gcov
*.lib
*.o
*.obj
*.profdata
*.profraw
*.so
*.dSYM/

# Rust
/target/
**/*.rs.bk

# Lua
.luacheckcache
*.luac
luac.out
