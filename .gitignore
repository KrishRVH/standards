# Repository maintenance ignores. Keep copyable consumer defaults in
# `shared/.gitignore`.

# OS/editor noise
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~
.#*

# Local environment/secrets
.env
.env.*
!.env.example
!.env.sample
!.env.template

# Logs and temporary files
*.log
*.tmp
*.temp
/.tmp/
/tmp/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Dependency directories
node_modules/
/vendor/
/testers/**/vendor/

# Generic generated output
/.gstack/
/.cache/
/build/
/coverage/
/dist/
/out/
/testers/**/.cache/
/testers/**/build/
/testers/**/coverage/
/testers/**/dist/
/testers/**/out/

# JavaScript / TypeScript
*.tsbuildinfo
.eslintcache
/.angular/
/.astro/
/.next/
/.nuxt/
/.nyc_output/
/.parcel-cache/
/.svelte-kit/
/.turbo/
/.vite/

# mise local state
mise.local.toml
mise.*.local.toml
.mise.local.toml
.mise.*.local.toml
mise.local.lock
mise.*.local.lock
.mise.local.lock
.mise.*.local.lock

# Dagger module local output
/dagger/.turbo/
/dagger/dist/
/testers/**/dagger/.turbo/
/testers/**/dagger/dist/

# PHP generated output
/.deptrac.cache
/.infection/
/.pdepend/
/.php-cs-fixer.cache
/.php-cs-fixer.php.cache
/.phpbench/
/.phpunit.cache/
/.phpunit.result.cache
/.phpstan.cache/
/.psalm-cache/
/.psalm/cache/
/.rector-cache/
/composer.phar
/var/cache/
/var/log/
