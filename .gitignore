# Repository maintenance ignores. Keep copyable consumer defaults in
# `shared/.gitignore`.

# OS/editor noise
.DS_Store
Thumbs.db
Desktop.ini
.idea/
*.swp
*.swo
*~
.#*

# Local environment/secrets
.env
.env.*
!.env.example
!.env.sample
!.env.template

# Logs and temporary files
*.log
*.tmp
*.temp
/.tmp/
/tmp/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Dependency directories
node_modules/
/vendor/
/testers/**/vendor/

# Generic generated output
/.gstack/
/.cache/
/build/
/coverage/
/dist/
/out/
/sbom/
**/.cache/
**/build/
**/coverage/
**/dist/
**/out/
**/sbom/

# Godot generated output
/.godot/
**/.godot/
*.translation

# JavaScript / TypeScript
*.tsbuildinfo
.eslintcache
/.angular/
/.astro/
/.next/
/.nuxt/
/.nyc_output/
/.parcel-cache/
/.svelte-kit/
/.turbo/
/.vite/

# Python generated output
.coverage
.mypy_cache/
.pytest_cache/
.ruff_cache/
.venv/
__pycache__/
*.egg-info/
/htmlcov/
/testers/**/.coverage
/testers/**/.mypy_cache/
/testers/**/.pytest_cache/
/testers/**/.ruff_cache/
/testers/**/.venv/
/testers/**/__pycache__/
/testers/**/*.egg-info/
/testers/**/htmlcov/

# mise local state
mise.local.toml
mise.*.local.toml
.mise.local.toml
.mise.*.local.toml
mise.local.lock
mise.*.local.lock
.mise.local.lock
.mise.*.local.lock

