/testers/**/.infection/
/testers/**/.pdepend/
/testers/**/.php-cs-fixer.cache
/testers/**/.php-cs-fixer.php.cache
/testers/**/.phpbench/
/testers/**/.phpunit.cache/
/testers/**/.phpunit.result.cache
/testers/**/.phpstan.cache
/testers/**/.phpstan.cache/
/testers/**/.psalm-cache/
/testers/**/.psalm/cache/
/testers/**/.rector-cache/
/testers/**/var/cache/
/testers/**/var/log/
infection-summary.log
infection.log

# C# / .NET generated output
/.vs/
/artifacts/
/TestResults/
**/[Bb]in/[Dd]ebug/
**/[Bb]in/[Rr]elease/
**/[Oo]bj/
*.nupkg
*.pdb
*.snupkg
*.sln.docstates
*.suo
*.user
*.userosscache

# C / CMake generated output
/CMakeCache.txt
/CMakeFiles/
/CTestTestfile.cmake
/DartConfiguration.tcl
/Testing/
/cmake_install.cmake
/compile_commands.json
*.a
*.dll
*.dylib
*.exe
*.gcda
*.gcno
*.gcov
*.lib
*.o
*.obj
*.profdata
*.profraw
*.so
*.dSYM/
