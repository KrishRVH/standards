{
  "name": "vendor/project",
  "description": "Reusable PHP quality-tooling baseline.",
  "license": "MIT",
  "type": "project",
  "authors": [
    {
      "name": "Project Maintainers"
    }
  ],
  "require": {
    "php": ">=8.4"
  },
  "require-dev": {
    "ergebnis/composer-normalize": "^2.52.0",
    "phpmd/phpmd": "^2.15.0",
    "phpstan/extension-installer": "^1.4.3",
    "phpstan/phpstan": "^2.2.2",
    "phpstan/phpstan-phpunit": "^2.0.16",
    "phpstan/phpstan-strict-rules": "^2.0.11",
    "phpunit/phpunit": "^12.5.30",
    "rector/rector": "^2.5.2",
    "roave/security-advisories": "dev-latest",
    "shipmonk/composer-dependency-analyser": "^1.8.4",
    "slevomat/coding-standard": "^8.29.0",
    "squizlabs/php_codesniffer": "^4.0.1"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "ergebnis/composer-normalize": true,
      "phpstan/extension-installer": true
    },
    "sort-packages": true
  },
  "scripts": {
    "analyze": "@phpstan",
    "composer:audit": "composer audit --locked --abandoned=report --format=summary",
    "composer:normalize": "composer normalize",
    "composer:validate": "composer validate --strict",
    "dependency-analyser": "composer-dependency-analyser",
    "deps": "@dependency-analyser",
    "lint": [
      "@style",
      "@analyze",
      "@smell"
    ],
    "normalize:check": "composer normalize --dry-run --diff",
    "phpcbf": "phpcbf",
    "phpcs": "phpcs",
    "phpmd": "php -d error_reporting='E_ALL & ~E_DEPRECATED & ~E_USER_DEPRECATED' vendor/bin/phpmd src text phpmd.xml",
    "phpstan": "php -d disable_functions=proc_open vendor/bin/phpstan analyse --memory-limit=512M",
    "rector": "rector process",
    "rector:dry": "rector process --dry-run",
    "smell": "@phpmd",
    "standards": [
      "@composer:normalize",
      "@rector",
      "@phpcbf",
      "@phpcs"
    ],
    "standards:check": [
      "@normalize:check",
      "@composer:validate",
      "@lint",
      "@test",
      "@deps",
      "@composer:audit",
      "@rector:dry"
    ],
    "style": "@phpcs",
    "test": "phpunit"
  },
  "scripts-descriptions": {
    "analyze": "Run static analysis (PHPStan).",
    "composer:audit": "Run Composer vulnerability and abandoned-package audit.",
    "composer:normalize": "Normalize composer.json.",
    "composer:validate": "Validate composer.json strictly.",
    "dependency-analyser": "Analyze dependency usage correctness (shipmonk/composer-dependency-analyser).",
    "deps": "Run dependency usage analysis.",
    "lint": "Run lint suite (style + static analysis).",
    "normalize:check": "Verify composer.json is normalized (dry-run + diff).",
    "phpcbf": "Auto-fix coding standard violations (PHPCBF).",
    "phpcs": "Check coding standards (PHPCS).",
    "phpmd": "Run maintainability smell checks (PHPMD).",
    "phpstan": "Run PHPStan analysis.",
    "rector": "Apply Rector automated refactorings.",
    "rector:dry": "Preview Rector refactorings without modifying files (dry-run).",
    "smell": "Run maintainability smell checks.",
    "standards": "Run the local standards workflow with autofixes.",
    "standards:check": "Run the standards CI gate.",
    "style": "Run style checks (PHPCS).",
    "test": "Run unit tests (PHPUnit)."
  }
}
