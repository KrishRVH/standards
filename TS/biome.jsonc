{
  "$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
  "root": true,

  // Keep VCS integration explicit so copied templates do not inherit local ignore behavior accidentally.
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": false,
  },

  // Include everything by default, then exclude generated/vendor/cache output at the Biome layer.
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**",
      "!!**/.angular",
      "!!**/.astro",
      "!!**/.cache",
      "!!**/.next",
      "!!**/.nuxt",
      "!!**/.nyc_output",
      "!!**/.parcel-cache",
      "!!**/.svelte-kit",
      "!!**/.turbo",
      "!!**/.vite",
      "!!**/build",
      "!!**/coverage",
      "!!**/dist",
      "!!**/node_modules",
      "!!**/out",
      "!**/*.tsbuildinfo",
    ],
  },

  // Shared formatter defaults mirror Prettier's low-surprise style while keeping Biome deterministic.
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 120,
    "bracketSameLine": false,
    "bracketSpacing": true,
    "trailingNewline": true,
  },

  // JavaScript/TypeScript-specific formatting choices not covered by the shared formatter block.
  "javascript": {
    "formatter": {
      "arrowParentheses": "always",
      "bracketSameLine": false,
      "bracketSpacing": true,
      "jsxQuoteStyle": "double",
      "quoteProperties": "asNeeded",
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all",
    },
  },

  // JSON files need no trailing commas even though this config file is JSONC.
  "json": {
    "formatter": {
      "bracketSpacing": true,
      "indentStyle": "space",
      "indentWidth": 2,
      "lineEnding": "lf",
      "lineWidth": 120,
      "trailingCommas": "none",
      "trailingNewline": true,
    },
  },

  // Organize imports by runtime/platform imports first, packages next, aliases, then relative paths.
  "assist": {
    "enabled": true,
    "actions": {
      "recommended": true,
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              [":BUN:", ":NODE:"],
              ":BLANK_LINE:",
              ":PACKAGE_WITH_PROTOCOL:",
              ":PACKAGE:",
              ":BLANK_LINE:",
              ":ALIAS:",
              ":BLANK_LINE:",
              ":PATH:",
            ],
            "identifierOrder": "lexicographic",
          },
        },
      },
    },
  },

  // Start from Biome's recommended baseline, then promote selected rules to a strict project default.
  "linter": {
    "enabled": true,
    "domains": {
      "project": "recommended",
      "test": "recommended",
      "types": "recommended",
    },
    "rules": {
      "recommended": true,

      "a11y": {
        "recommended": true,
        "noAutofocus": "error",
        "noDistractingElements": "error",
        "noPositiveTabindex": "error",
        "noSvgWithoutTitle": "error",
        "useKeyWithClickEvents": "error",
        "useKeyWithMouseEvents": "error",
        "useMediaCaption": "error",
      },

      "complexity": {
        "recommended": true,
        "noArguments": "error",
        "noBannedTypes": "error",
        "noCommaOperator": "error",
        "noImplicitCoercions": "error",
        "noStaticOnlyClass": "error",
        "useArrowFunction": "error",
        "useDateNow": "error",
        "useFlatMap": "error",
        "useLiteralKeys": "error",
        "useNumericLiterals": "error",
        "useOptionalChain": "error",
        "useRegexLiterals": "error",
        "useSimplifiedLogicExpression": "error",
      },

      "correctness": {
        "recommended": true,
        "noInvalidUseBeforeDeclaration": "error",
        "noNestedComponentDefinitions": "error",
        "noPrivateImports": "error",
        "noUnusedFunctionParameters": "error",
        "noUnusedImports": "error",
        "noUnusedVariables": "error",
        "noVoidTypeReturn": "error",
        "useIsNan": "error",
        "useJsxKeyInIterable": "error",
        "useParseIntRadix": "error",
        "useValidTypeof": "error",
      },

      "nursery": {
        "noEqualsToNull": "error",
        "noFloatingPromises": "error",
        "noForIn": "error",
        "noImpliedEval": "error",
        "noLoopFunc": "error",
        "noMisusedPromises": "error",
        "noNestedPromises": "error",
        "noReturnAssign": "error",
        "noShadow": "error",
        "noUnnecessaryConditions": "error",
        "noUnnecessaryTemplateExpression": "error",
        "noUnsafePlusOperands": "error",
        "useArraySome": "error",
        "useAwaitThenable": "error",
        "useErrorCause": "error",
        "useExhaustiveSwitchCases": "error",
        "useFind": "error",
        "useGlobalThis": "error",
        "useNullishCoalescing": "error",
        "useRegexpExec": "error",
        "useRegexpTest": "error",
        "useStringStartsEndsWith": "error",
      },

      "performance": {
        "recommended": true,
        "noAccumulatingSpread": "error",
        "noAwaitInLoops": "error",
        "noDelete": "error",
        "noDynamicNamespaceImportAccess": "error",
        "noReExportAll": "error",
        "useTopLevelRegex": "error",
      },

      "security": {
        "recommended": true,
        "noBlankTarget": "error",
        "noDangerouslySetInnerHtml": "error",
        "noDangerouslySetInnerHtmlWithChildren": "error",
        "noGlobalEval": "error",
        "noSecrets": {
          "level": "error",
          "options": {
            "entropyThreshold": 50,
          },
        },
      },

      "style": {
        "recommended": true,
        "noCommonJs": "error",
        "noDefaultExport": "error",
        "noEnum": "error",
        "noNamespace": "error",
        "noNonNullAssertion": "error",
        "noParameterAssign": "error",
        "noParameterProperties": "error",
        "noUselessElse": "error",
        "noYodaExpression": "error",
        "useAsConstAssertion": "error",
        "useBlockStatements": "error",
        "useConst": "error",
        "useDefaultParameterLast": "error",
        "useEnumInitializers": "error",
        "useExportType": "error",
        "useImportType": "error",
        "useNodejsImportProtocol": "error",
        "useNumberNamespace": "error",
        "useObjectSpread": "error",
        "useSelfClosingElements": "error",
        "useShorthandAssign": "error",
        "useShorthandFunctionType": "error",
        "useSingleVarDeclarator": "error",
        "useTemplate": "error",
        "useThrowNewError": "error",
        "useThrowOnlyError": "error",
      },

      "suspicious": {
        "recommended": true,
        "noAssignInExpressions": "error",
        "noDebugger": "error",
        "noDoubleEquals": "error",
        "noDuplicateDependencies": "error",
        "noExplicitAny": "error",
        "noFocusedTests": "error",
        "noImplicitAnyLet": "error",
        "noSkippedTests": "error",
        "noTsIgnore": "error",
        "noVar": "error",
        "useAwait": "error",
        "useGuardForIn": "error",
        "useIterableCallbackReturn": "error",
        "useStrictMode": "error",
      },
    },
  },

  // File-type escape hatches for cases where the strict baseline conflicts with common ecosystem patterns.
  "overrides": [
    {
      // Ambient declaration files may need namespaces for module/global augmentation.
      "includes": ["**/*.d.ts"],
      "linter": {
        "rules": {
          "style": {
            "noNamespace": "off",
          },
        },
      },
    },
    {
      // Tool config files commonly use default exports because their loaders expect them.
      "includes": [
        "**/*.config.{js,mjs,ts}",
        "**/eslint.config.{js,mjs,ts}",
        "**/prettier.config.{js,mjs,ts}",
        "**/vite.config.{js,mjs,ts}",
      ],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off",
          },
        },
      },
    },
    {
      // Tests commonly log and use fixture strings that can resemble secrets.
      "includes": ["**/*.{test,spec}.{js,jsx,ts,tsx}", "**/__tests__/**/*.{js,jsx,ts,tsx}"],
      "linter": {
        "rules": {
          "security": {
            "noSecrets": "off",
          },
          "suspicious": {
            "noConsole": "off",
          },
        },
      },
    },
  ],
}
