{
  "name": "project-name",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "build": "bun run typecheck",
    "ci": "bun run standards:check && bun run test",
    "format:check": "prettier . --check",
    "format:fix": "prettier . --write --cache --list-different",
    "lint": "bun run lint:check",
    "lint:check": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "standards": "bun run lint:fix && bun run format:fix && bun run typecheck",
    "standards:check": "bun run lint:check && bun run typecheck && bun run format:check",
    "test": "bun run tests/math.test.ts",
    "typecheck": "tsc --pretty --noEmit -p tsconfig.json",
    "watch": "tsc --pretty --noEmit --watch -p tsconfig.json"
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
