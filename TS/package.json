{
  "name": "project-name",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "audit": "bun audit --audit-level=low",
    "format": "prettier . --write --cache --list-different",
    "format:check": "prettier . --check",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "standards": "bun run format && bun run lint:fix",
    "standards:check": "bun run lint && bun run typecheck && bun run format:check && bun run test && bun run audit",
    "test": "bun test",
    "typecheck": "tsc --pretty --noEmit -p tsconfig.json"
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.5",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
