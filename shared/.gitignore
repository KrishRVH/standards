# Intent: ignore generated/local artifacts only. Keep lockfiles, fixtures,
# corpora, examples, Makefiles, and shared editor config visible by default.

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Editor temporary files, not editor project config
*.swp
*.swo
*~
.#*

# Local environment/secrets
.env
.env.*
!.env.example
!.env.sample
!.env.template

# Logs and temporary files
*.log
*.tmp
*.temp
/.tmp/
/tmp/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Dependency directories
node_modules/
/vendor/

# Generic generated output
/.gstack/
/.cache/
/build/
/coverage/
/dist/
/out/

