# Normalize text files to LF by default. Override only where a platform format is
# required for execution.
* text=auto eol=lf

# Shell and platform scripts
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

