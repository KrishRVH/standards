# GitHub Linguist
#
# This repository is a standards-template catalog. Tester mini projects and
# copied fixture wiring prove the templates work, but they should not dominate
# the repository language graph on GitHub.
testers/** linguist-detectable=false

# Root maintenance scripts support this catalog, but the language graph should
# describe the reusable standards templates.
scripts/** linguist-detectable=false

# Shell helpers are copyable build/check glue, not the primary language surface
# of the C standard.
C/c-build.sh linguist-detectable=false
C/c-quality.sh linguist-detectable=false
C++/cpp-build.sh linguist-detectable=false
C++/cpp-quality.sh linguist-detectable=false

# Attribute language-specific build and quality-tool config to the template it
# configures so GitHub's chart reflects the standards catalog instead of the
# implementation language of the config file.
C/CMakeLists.txt linguist-language=C
C/*.cmake linguist-language=C
C/**/*.cmake linguist-language=C
C/**/*.cmake.in linguist-language=C
C++/CMakeLists.txt linguist-language=C++
C++/*.cmake linguist-language=C++
C++/**/*.cmake linguist-language=C++
C++/**/*.cmake.in linguist-language=C++
TS/*.mjs linguist-language=TypeScript

# GitHub Linguist does not have a separate SPARK language bucket; SPARK/Ada
# templates therefore need to land in Ada to stay visible.
SPARK/*.adc linguist-language=Ada
SPARK/*.gpr linguist-language=Ada
SPARK/*.toml linguist-language=Ada

# The stack-specific mise task files are part of each language standard, not a
# standalone TOML codebase.
Mise/conf.d/20-fortran.toml linguist-language=Fortran
Mise/conf.d/20-haskell.toml linguist-language=Haskell
Mise/conf.d/20-spark.toml linguist-language=Ada

# Workstation setup scripts are bootstrap templates, not the primary language
# surface of this standards catalog.
extras/workstation/macbook-setup.sh linguist-detectable=false
extras/workstation/wsl-setup.sh linguist-detectable=false

# Generated or dependency-derived files should stay out of Linguist stats if
# they are ever present in a fixture.
*.lock linguist-generated=true
**/.coverage linguist-generated=true
**/.phpunit.cache/** linguist-generated=true
**/__pycache__/** linguist-generated=true
**/_build/** linguist-generated=true
**/.gradle/** linguist-generated=true
**/.kotlin/** linguist-generated=true
**/.stack-work/** linguist-generated=true
**/.zig-cache/** linguist-generated=true
**/cover/** linguist-generated=true
**/deps/** linguist-vendored=true linguist-detectable=false
**/dist-newstyle/** linguist-generated=true
**/vendor/** linguist-vendored=true linguist-detectable=false
**/zig-cache/** linguist-generated=true
**/zig-out/** linguist-generated=true
**/zig-pkg/** linguist-vendored=true linguist-detectable=false
